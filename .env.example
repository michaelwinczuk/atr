# ===========================================
# Agent Transaction Router — Configuration
# ===========================================

# Server
PORT=3000
DATABASE_URL=sqlite:atr.db?mode=rwc

# Admin (set this to secure the /admin/* endpoints)
ATR_ADMIN_KEY=change-me-to-a-random-secret

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Confirmation poller interval
POLL_INTERVAL_SECS=10

# --- Solana ---
# RPC URL (comma-separated for failover)
# Devnet: https://api.devnet.solana.com
# Mainnet: Get from Helius, QuickNode, or Triton
SOLANA_RPC_URL=https://api.devnet.solana.com

# Base58-encoded private key (64 bytes)
# Generate with: cargo run -p atr-server --bin keygen
SOLANA_PRIVATE_KEY=

# --- Base (Ethereum L2) ---
# RPC URL (comma-separated for failover)
# Sepolia testnet: https://sepolia.base.org
# Mainnet: https://mainnet.base.org or Alchemy/QuickNode
BASE_RPC_URL=https://sepolia.base.org

# Hex-encoded private key (with or without 0x prefix)
# Generate with: cargo run -p atr-server --bin keygen
BASE_PRIVATE_KEY=

# --- Shape (Ethereum L2, OP Stack) ---
# Gasback-enabled: 80% of sequencer fees returned to contract deployers
# Mainnet: https://mainnet.shape.network
SHAPE_RPC_URL=https://mainnet.shape.network

# Same key format as Base (hex-encoded, 0x prefix optional)
SHAPE_PRIVATE_KEY=
